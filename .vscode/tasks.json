{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "xv6 build",
            "type": "shell",
            "command": "make qemu-nox-gdb",
            "isBackground": true,
            "problemMatcher":{
                "pattern": {
                    "regexp": ".",
                    "file": 1,
                    "location": 2,
                    "message": 3
                },
                "background": {
                    "beginsPattern":".*Now run 'gdb'.",
                    "endsPattern":"."
                }
            }
        }
    ]
}